# 网关监听配置
AUTOMATION_HOST=127.0.0.1
AUTOMATION_PORT=8000
AUTOMATION_LOG_LEVEL=INFO

# Playwright 公共配置。生产环境建议使用已安装的 Chrome channel。
AUTOMATION_HEADLESS=false
AUTOMATION_BROWSER_CHANNEL=chrome
AUTOMATION_DEFAULT_TIMEOUT_MS=30000
AUTOMATION_MAX_BROWSER_CONTEXTS=4

# 自愈执行器：local 使用已认证 Codex CLI；http 使用远程执行器。
AUTOMATION_HEALING_BACKEND=local
AUTOMATION_CODEX_COMMAND=codex
AUTOMATION_HEALING_URL=
AUTOMATION_HEALING_TOKEN=
AUTOMATION_HEALING_TIMEOUT_SECONDS=600
